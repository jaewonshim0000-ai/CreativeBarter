// Prisma Schema for Creative Barter Network
// Connection config lives in prisma.config.ts (Prisma 7+)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuidOssp(map: "uuid-ossp"), postgis]
}

// ============================================================
// User Model
// ============================================================

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  name            String
  profileImageUrl String?  @map("profile_image_url")
  bio             String?
  specialty       String   @default("other")
  city            String?
  region          String?
  latitude        Float?
  longitude       Float?
  role            String   @default("user")
  portfolio       Json     @default("[]")
  avgRating       Float    @default(0) @map("avg_rating")
  totalReviews    Int      @default(0) @map("total_reviews")
  creditsBalance  Int      @default(100) @map("credits_balance")
  showOnMap       Boolean  @default(false) @map("show_on_map")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  skills           UserSkill[]
  resources        UserResource[]
  projects         Project[]
  proposedMatches  Match[]        @relation("proposer")
  receivedMatches  Match[]        @relation("receiver")
  sentMessages     Message[]      @relation("sender")
  receivedMessages Message[]      @relation("receiver_msg")
  givenReviews     Review[]       @relation("reviewer")
  receivedReviews  Review[]       @relation("reviewed")
  notifications    Notification[]
  // Circular barter relations
  initiatedChains       BarterChain[]             @relation("chain_initiator")
  chainParticipations   BarterChainParticipant[]   @relation("chain_participant")
  chainGivesTo          BarterChainParticipant[]   @relation("chain_gives_to")
  chainReceivesFrom     BarterChainParticipant[]   @relation("chain_receives_from")
  wants                 UserWant[]
  // Credit relations
  creditTransactions    CreditTransaction[]    @relation("credit_user")
  creditTransactionsAsRelated CreditTransaction[] @relation("credit_related_user")
  proposedOffers        CreditOffer[]          @relation("offer_proposer")
  payerOffers           CreditOffer[]          @relation("offer_payer")
  payeeOffers           CreditOffer[]          @relation("offer_payee")

  @@map("users")
}

// ============================================================
// Skill Model
// ============================================================

model Skill {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  category    String?
  createdAt   DateTime    @default(now()) @map("created_at")
  users       UserSkill[]

  @@map("skills")
}

model UserSkill {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  skillId         String   @map("skill_id")
  proficiency     String   @default("beginner")
  yearsExperience Int      @default(0) @map("years_experience")
  createdAt       DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("user_skills")
}

// ============================================================
// Resource Model
// ============================================================

model Resource {
  id           String         @id @default(uuid())
  name         String         @unique
  description  String?
  resourceType String?        @map("resource_type")
  createdAt    DateTime       @default(now()) @map("created_at")
  users        UserResource[]

  @@map("resources")
}

model UserResource {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  resourceId   String   @map("resource_id")
  details      String?
  availability String   @default("available")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@map("user_resources")
}

// ============================================================
// Project Model
// ============================================================

model Project {
  id                String   @id @default(uuid())
  creatorId         String   @map("creator_id")
  title             String
  description       String
  requiredSkills    Json     @default("[]") @map("required_skills")
  requiredResources Json     @default("[]") @map("required_resources")
  offeredSkills     Json     @default("[]") @map("offered_skills")
  offeredResources  Json     @default("[]") @map("offered_resources")
  status            String   @default("open")
  latitude          Float?
  longitude         Float?
  city              String?
  region            String?
  deadline          DateTime?
  maxCollaborators  Int      @default(5) @map("max_collaborators")
  tags              Json     @default("[]")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  creator  User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  matches  Match[]
  messages Message[]
  reviews  Review[]

  @@map("projects")
}

// ============================================================
// Match Model
// ============================================================

model Match {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  proposerId String   @map("proposer_id")
  receiverId String   @map("receiver_id")
  status     String   @default("pending")
  message    String?
  matchScore Float?   @map("match_score")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  proposer User    @relation("proposer", fields: [proposerId], references: [id], onDelete: Cascade)
  receiver User    @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  creditOffers     CreditOffer[]
  creditTransactions CreditTransaction[]

  @@unique([projectId, proposerId, receiverId])
  @@map("matches")
}

// ============================================================
// Message Model
// ============================================================

model Message {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  projectId  String?  @map("project_id")
  content    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User     @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User     @relation("receiver_msg", fields: [receiverId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("messages")
}

// ============================================================
// Review Model
// ============================================================

model Review {
  id             String   @id @default(uuid())
  reviewerId     String   @map("reviewer_id")
  reviewedUserId String   @map("reviewed_user_id")
  projectId      String   @map("project_id")
  rating         Int
  content        String?
  createdAt      DateTime @default(now()) @map("created_at")

  reviewer     User    @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewedUser User    @relation("reviewed", fields: [reviewedUserId], references: [id], onDelete: Cascade)
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, reviewedUserId, projectId])
  @@map("reviews")
}

// ============================================================
// Notification Model
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String?
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================================
// Barter Chain Model (Circular Exchange)
// ============================================================

model BarterChain {
  id              String    @id @default(uuid())
  title           String
  description     String?
  status          String    @default("proposed")
  chainLength     Int       @map("chain_length")
  initiatedBy     String    @map("initiated_by")
  confidenceScore Float?    @map("confidence_score")
  expiresAt       DateTime? @map("expires_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  initiator    User                     @relation("chain_initiator", fields: [initiatedBy], references: [id], onDelete: Cascade)
  participants BarterChainParticipant[]

  @@map("barter_chains")
}

model BarterChainParticipant {
  id                  String    @id @default(uuid())
  chainId             String    @map("chain_id")
  userId              String    @map("user_id")
  position            Int
  givesSkill          String    @map("gives_skill")
  givesDescription    String?   @map("gives_description")
  givesToUserId       String    @map("gives_to_user_id")
  receivesSkill       String    @map("receives_skill")
  receivesDescription String?   @map("receives_description")
  receivesFromUserId  String    @map("receives_from_user_id")
  status              String    @default("pending")
  acceptedAt          DateTime? @map("accepted_at")
  completedAt         DateTime? @map("completed_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  chain       BarterChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  user        User        @relation("chain_participant", fields: [userId], references: [id], onDelete: Cascade)
  givesToUser User        @relation("chain_gives_to", fields: [givesToUserId], references: [id], onDelete: Cascade)
  receivesFromUser User   @relation("chain_receives_from", fields: [receivesFromUserId], references: [id], onDelete: Cascade)

  @@unique([chainId, userId])
  @@unique([chainId, position])
  @@map("barter_chain_participants")
}

// ============================================================
// User Wants Model (skills/resources a user is looking for)
// ============================================================

model UserWant {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  skillName String   @map("skill_name")
  description String?
  priority  Int      @default(5)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillName])
  @@map("user_wants")
}

// ============================================================
// Credit Transaction Model (ledger)
// ============================================================

model CreditTransaction {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  amount        Int                        // positive = earn, negative = spend
  balanceAfter  Int      @map("balance_after")
  type          String                     // signup_bonus, trade_payment, trade_earning, etc.
  description   String?
  relatedMatchId String? @map("related_match_id")
  relatedUserId  String? @map("related_user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user         User   @relation("credit_user", fields: [userId], references: [id], onDelete: Cascade)
  relatedUser  User?  @relation("credit_related_user", fields: [relatedUserId], references: [id], onDelete: SetNull)
  relatedMatch Match? @relation(fields: [relatedMatchId], references: [id], onDelete: SetNull)

  @@map("credit_transactions")
}

// ============================================================
// Credit Offer Model (negotiation on matches)
// ============================================================

model CreditOffer {
  id            String    @id @default(uuid())
  matchId       String    @map("match_id")
  proposedBy    String    @map("proposed_by")
  amount        Int                       // credits being offered
  payerId       String    @map("payer_id")
  payeeId       String    @map("payee_id")
  status        String    @default("proposed")  // proposed, countered, accepted, rejected, expired
  note          String?
  counterAmount Int?      @map("counter_amount")
  counterNote   String?   @map("counter_note")
  acceptedAt    DateTime? @map("accepted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  match     Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  proposer  User  @relation("offer_proposer", fields: [proposedBy], references: [id], onDelete: Cascade)
  payer     User  @relation("offer_payer", fields: [payerId], references: [id], onDelete: Cascade)
  payee     User  @relation("offer_payee", fields: [payeeId], references: [id], onDelete: Cascade)

  @@map("credit_offers")
}
